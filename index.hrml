    <!-- 4. NAVIGATION JAVASCRIPT -->
    <script>
        function switchTab(tabId) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(element => {
                element.classList.add('hidden');
            });

            // Show active tab content
            document.getElementById('tab-' + tabId).classList.remove('hidden');

            // Deactivate all navigation items
            document.querySelectorAll('.nav-item').forEach(element => {
                element.classList.remove('active-nav');
            });

            // Activate current navigation item
            document.getElementById('nav-' + tabId).classList.add('active-nav');

            // Map and update page titles nicely
            const pageTitles = {
                'dashboard': 'Dashboard',
                'sales': 'Sales Invoice AI Workspace',
                'purchase': 'Purchase Invoice AI Workspace',
                'masters': 'System Master Records',
                'settings': 'Global Configuration & Integrations'
            };
            document.getElementById('page-title').innerText = pageTitles[tabId];
        }
    </script>

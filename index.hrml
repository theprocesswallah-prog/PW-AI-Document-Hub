<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Processwallah AI Document Hub</title>
    
    <!-- Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    
    <!-- Stylesheets -->
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="css/responsive.css">
</head>
<body>

    <div class="app-container">
        
        <!-- Sidebar Navigation -->
        <aside class="app-sidebar" id="appSidebar">
            <div class="sidebar-header">
                <div class="brand-logo">
                    <span class="material-symbols-rounded">neurology</span>
                </div>
                <div class="brand-info">
                    <h1 class="brand-name">Processwallah</h1>
                    <span class="brand-tag">AI Document Hub</span>
                </div>
            </div>

            <nav class="sidebar-nav">
                <a href="#/dashboard" class="nav-link active" id="nav-dashboard">
                    <span class="material-symbols-rounded">dashboard</span>
                    <span class="nav-label">Dashboard</span>
                </a>
                
                <div class="nav-group-label">Sales Department</div>
                <a href="#/sales-upload" class="nav-link" id="nav-sales-upload">
                    <span class="material-symbols-rounded">upload_file</span>
                    <span class="nav-label">AI Upload</span>
                </a>
                <a href="#/sales-register" class="nav-link" id="nav-sales-register">
                    <span class="material-symbols-rounded">analytics</span>
                    <span class="nav-label">Sales Register</span>
                </a>

                <div class="nav-group-label">Purchase Department</div>
                <a href="#/purchase-upload" class="nav-link" id="nav-purchase-upload">
                    <span class="material-symbols-rounded">receipt_long</span>
                    <span class="nav-label">Bill Upload</span>
                </a>
                <a href="#/purchase-register" class="nav-link" id="nav-purchase-register">
                    <span class="material-symbols-rounded">payments</span>
                    <span class="nav-label">Purchase Register</span>
                </a>

                <div class="nav-group-label">System</div>
                <a href="#/masters" class="nav-link" id="nav-masters">
                    <span class="material-symbols-rounded">database</span>
                    <span class="nav-label">Masters</span>
                </a>
                <a href="#/settings" class="nav-link" id="nav-settings">
                    <span class="material-symbols-rounded">settings</span>
                    <span class="nav-label">Settings</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="system-status">
                    <span class="status-indicator online"></span>
                    <span class="status-text">Gemini Engine Ready</span>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="main-layout">
            
            <!-- Global Header -->
            <header class="app-header">
                <div class="header-left">
                    <button class="menu-toggle-btn" id="menuToggle" aria-label="Toggle Menu">
                        <span class="material-symbols-rounded">menu</span>
                    </button>
                    <div class="breadcrumb">
                        <span class="breadcrumb-parent">Workspace</span>
                        <span class="breadcrumb-separator">/</span>
                        <span class="breadcrumb-current" id="currentBreadcrumb">Dashboard</span>
                    </div>
                </div>

                <div class="header-right">
                    <div class="session-stat">
                        <span class="material-symbols-rounded text-accent">bolt</span>
                        <span class="stat-lbl">Session Avg: <strong id="sessionAvg">1m 45s</strong></span>
                    </div>
                    
                    <div class="user-profile">
                        <div class="profile-details">
                            <span class="profile-name">Finance Operations</span>
                            <span class="profile-role">Department Admin</span>
                        </div>
                        <div class="profile-avatar">FO</div>
                    </div>
                </div>
            </header>

            <!-- Dynamic Viewport -->
            <main class="app-content-viewport" id="contentViewport">
                <!-- Routed templates load dynamically here -->
            </main>
            
        </div>
    </div>

    <!-- Application Scripts -->
    <script src="js/utils.js"></script>
    <script src="js/ui.js"></script>
    <script src="js/router.js"></script>
    <script src="js/app.js"></script>
</body>
</html>

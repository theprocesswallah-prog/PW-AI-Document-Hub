<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Processwallah AI Document Hub</title>
    <!-- Google Fonts & Tailwind CSS CDN -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#5E35B1',
                        secondary: '#673AB7',
                        accent: '#7E57C2',
                        background: '#F5F7FA',
                        sidebar: '#FFFFFF',
                        card: '#FFFFFF'
                    },
                    borderRadius: {
                        'enterprise': '14px'
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-rounded {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .active-nav {
            background-color: #F5F7FA;
            color: #5E35B1;
            font-weight: 600;
            border-left: 4px solid #5E35B1;
        }
        /* Custom scrollbar styling for enterprise grids */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #F1F1F1;
        }
        ::-webkit-scrollbar-thumb {
            background: #C1C1C1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #A8A8A8;
        }
    </style>
</head>
<body class="bg-[#F5F7FA] text-slate-800 font-sans min-h-screen flex flex-col overflow-x-hidden">

    <!-- App Shell Container -->
    <div class="flex flex-1 h-screen overflow-hidden">
        
        <!-- 1. LEFT SIDEBAR -->
        <aside class="w-64 bg-white border-r border-slate-200 flex flex-col justify-between shrink-0 hidden md:flex">
            <div>
                <!-- Logo & Brand Header -->
                <div class="p-6 border-b border-slate-100 flex items-center gap-3">
                    <div class="h-10 w-10 bg-[#5E35B1] rounded-[14px] flex items-center justify-center text-white">
                        <span class="material-symbols-rounded text-2xl">neurology</span>
                    </div>
                    <div>
                        <h1 class="font-bold text-slate-900 tracking-tight leading-none text-base">Processwallah</h1>
                        <span class="text-[11px] text-[#7E57C2] font-semibold uppercase tracking-wider">AI Document Hub</span>
                    </div>
                </div>

                <!-- Navigation Links -->
                <nav class="p-4 space-y-1">
                    <button onclick="switchTab('dashboard')" id="nav-dashboard" class="nav-item active-nav w-full flex items-center gap-3 px-4 py-3 rounded-[14px] text-slate-600 hover:bg-slate-50 transition-colors text-sm">
                        <span class="material-symbols-rounded">dashboard</span>
                        <span>Dashboard</span>
                    </button>
                    <button onclick="switchTab('sales')" id="nav-sales" class="nav-item w-full flex items-center justify-between px-4 py-3 rounded-[14px] text-slate-600 hover:bg-slate-50 transition-colors text-sm">
                        <div class="flex items-center gap-3">
                            <span class="material-symbols-rounded">description</span>
                            <span>Sales Invoices</span>
                        </div>
                        <span class="bg-indigo-100 text-[#5E35B1] text-[10px] font-bold px-2 py-0.5 rounded-full">4 New</span>
                    </button>
                    <button onclick="switchTab('purchase')" id="nav-purchase" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-[14px] text-slate-600 hover:bg-slate-50 transition-colors text-sm">
                        <span class="material-symbols-rounded">receipt</span>
                        <span>Purchase Bills</span>
                    </button>
                    <button onclick="switchTab('masters')" id="nav-masters" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-[14px] text-slate-600 hover:bg-slate-50 transition-colors text-sm">
                        <span class="material-symbols-rounded">database</span>
                        <span>Masters</span>
                    </button>
                    <button onclick="switchTab('settings')" id="nav-settings" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-[14px] text-slate-600 hover:bg-slate-50 transition-colors text-sm">
                        <span class="material-symbols-rounded">settings</span>
                        <span>Settings</span>
                    </button>
                </nav>
            </div>

            <!-- Footer Meta Info -->
            <div class="p-4 border-t border-slate-100 bg-slate-50">
                <div class="flex items-center gap-3 mb-2">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                    </span>
                    <span class="text-xs font-medium text-slate-500">Gemini-1.5-Flash Active</span>
                </div>
                <p class="text-[11px] text-slate-400 leading-tight">Target: Google Sheet Database</p>
            </div>
        </aside>

        <!-- Main Workspace Area -->
        <main class="flex-1 flex flex-col overflow-hidden">
            
            <!-- 2. TOP HEADER -->
            <header class="h-16 bg-white border-b border-slate-200 px-6 flex items-center justify-between shrink-0">
                <!-- Breadcrumb Title -->
                <div class="flex items-center gap-3">
                    <button class="md:hidden text-slate-600 p-1 rounded-lg hover:bg-slate-100">
                        <span class="material-symbols-rounded">menu</span>
                    </button>
                    <div>
                        <span class="text-xs text-slate-400 font-medium">Workspace</span>
                        <h2 id="page-title" class="text-base font-semibold text-slate-800 leading-none">Dashboard</h2>
                    </div>
                </div>

                <!-- Global Quick Stats / Profile -->
                <div class="flex items-center gap-6">
                    <!-- Session Speed Stat -->
                    <div class="hidden lg:flex items-center gap-2 bg-indigo-50 px-3 py-1.5 rounded-full border border-indigo-100">
                        <span class="material-symbols-rounded text-indigo-600 text-lg">bolt</span>
                        <span class="text-xs font-semibold text-indigo-900">Avg. Entry: <span class="text-[#5E35B1]">1m 45s</span></span>
                    </div>

                    <!-- User Information -->
                    <div class="flex items-center gap-3">
                        <div class="text-right hidden sm:block">
                            <span class="text-xs font-semibold text-slate-700 block">Finance Operations</span>
                            <span class="text-[10px] text-slate-400 block">finance-ops@company.com</span>
                        </div>
                        <div class="h-9 w-9 rounded-[14px] bg-slate-100 border border-slate-200 flex items-center justify-center text-[#5E35B1] font-bold text-sm">
                            FO
                        </div>
                    </div>
                </div>
            </header>

            <!-- 3. PAGE CONTENT CONTAINER -->
            <div class="flex-1 overflow-y-auto p-6 space-y-6">

                <!-- PAGE 1: DASHBOARD -->
                <div id="tab-dashboard" class="tab-content space-y-6">
                    <!-- Stat Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-5">
                        <div class="bg-white p-5 rounded-[14px] border border-slate-200 flex items-center justify-between shadow-sm">
                            <div>
                                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider block mb-1">Total Uploads</span>
                                <h3 class="text-2xl font-bold text-slate-800">1,248</h3>
                                <span class="text-xs text-emerald-600 flex items-center gap-1 mt-1 font-medium">
                                    <span class="material-symbols-rounded text-sm">arrow_upward</span> +12% this week
                                </span>
                            </div>
                            <div class="h-12 w-12 bg-indigo-50 rounded-[14px] flex items-center justify-center text-[#5E35B1]">
                                <span class="material-symbols-rounded text-2xl">cloud_upload</span>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-[14px] border border-slate-200 flex items-center justify-between shadow-sm">
                            <div>
                                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider block mb-1">Avg. Review Time</span>
                                <h3 class="text-2xl font-bold text-slate-800">1m 52s</h3>
                                <span class="text-xs text-indigo-600 flex items-center gap-1 mt-1 font-medium">
                                    <span class="material-symbols-rounded text-sm">offline_bolt</span> Saved 3m 08s / doc
                                </span>
                            </div>
                            <div class="h-12 w-12 bg-violet-50 rounded-[14px] flex items-center justify-center text-[#673AB7]">
                                <span class="material-symbols-rounded text-2xl">avg_time</span>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-[14px] border border-slate-200 flex items-center justify-between shadow-sm">
                            <div>
                                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider block mb-1">Extraction Accuracy</span>
                                <h3 class="text-2xl font-bold text-slate-800">94.2%</h3>
                                <span class="text-xs text-slate-500 block mt-1">Based on Gemini confidence</span>
                            </div>
                            <div class="h-12 w-12 bg-emerald-50 rounded-[14px] flex items-center justify-center text-emerald-600">
                                <span class="material-symbols-rounded text-2xl">verified</span>
                            </div>
                        </div>

                        <div class="bg-white p-5 rounded-[14px] border border-slate-200 flex items-center justify-between shadow-sm">
                            <div>
                                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider block mb-1">Pending Sync</span>
                                <h3 class="text-2xl font-bold text-slate-800">9 Docs</h3>
                                <span class="text-xs text-[#7E57C2] flex items-center gap-1 mt-1 font-medium">
                                    <span class="material-symbols-rounded text-sm">hourglass_empty</span> Ready for validation
                                </span>
                            </div>
                            <div class="h-12 w-12 bg-amber-50 rounded-[14px] flex items-center justify-center text-amber-600">
                                <span class="material-symbols-rounded text-2xl">pending_actions</span>
                            </div>
                        </div>
                    </div>

                    <!-- Workflow Tracking Section -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                        <!-- Recent Activity / Queue -->
                        <div class="bg-white rounded-[14px] border border-slate-200 shadow-sm lg:col-span-2">
                            <div class="p-5 border-b border-slate-100 flex items-center justify-between">
                                <h3 class="font-bold text-slate-800 text-sm">Processing Pipeline Queue</h3>
                                <span class="text-xs text-[#5E35B1] font-semibold hover:underline cursor-pointer">View All</span>
                            </div>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left text-xs">
                                    <thead class="bg-slate-50 text-slate-500 uppercase font-semibold border-b border-slate-100">
                                        <tr>
                                            <th class="px-5 py-3">Document ID</th>
                                            <th class="px-5 py-3">Vendor / Entity</th>
                                            <th class="px-5 py-3">Upload Date</th>
                                            <th class="px-5 py-3">Confidence</th>
                                            <th class="px-5 py-3">Status</th>
                                            <th class="px-5 py-3 text-right">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100">
                                        <tr>
                                            <td class="px-5 py-4 font-semibold text-slate-700">INV-2025-0041</td>
                                            <td class="px-5 py-4">Acme Tech Solutions</td>
                                            <td class="px-5 py-4 text-slate-500">Today, 10:45 AM</td>
                                            <td class="px-5 py-4">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-12 bg-slate-200 rounded-full h-1.5">
                                                        <div class="bg-emerald-500 h-1.5 rounded-full" style="width: 96%"></div>
                                                    </div>
                                                    <span class="text-emerald-600 font-bold">96%</span>
                                                </div>
                                            </td>
                                            <td class="px-5 py-4">
                                                <span class="bg-amber-100 text-amber-800 px-2 py-0.5 rounded-full font-medium text-[10px]">Review Pending</span>
                                            </td>
                                            <td class="px-5 py-4 text-right">
                                                <button onclick="switchTab('sales')" class="bg-[#5E35B1] text-white px-3 py-1 rounded-[8px] font-medium hover:bg-[#673AB7] transition-all">Review</button>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="px-5 py-4 font-semibold text-slate-700">PO-8849-01</td>
                                            <td class="px-5 py-4">Global Logistics Inc.</td>
                                            <td class="px-5 py-4 text-slate-500">Yesterday</td>
                                            <td class="px-5 py-4">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-12 bg-slate-200 rounded-full h-1.5">
                                                        <div class="bg-yellow-500 h-1.5 rounded-full" style="width: 74%"></div>
                                                    </div>
                                                    <span class="text-yellow-600 font-bold">74%</span>
                                                </div>
                                            </td>
                                            <td class="px-5 py-4">
                                                <span class="bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full font-medium text-[10px]">Low Confidence</span>
                                            </td>
                                            <td class="px-5 py-4 text-right">
                                                <button onclick="switchTab('purchase')" class="bg-[#5E35B1] text-white px-3 py-1 rounded-[8px] font-medium hover:bg-[#673AB7] transition-all">Review</button>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="px-5 py-4 font-semibold text-slate-700">INV-2025-0040</td>
                                            <td class="px-5 py-4">Nvidia Corp India</td>
                                            <td class="px-5 py-4 text-slate-500">Yesterday</td>
                                            <td class="px-5 py-4">
                                                <div class="flex items-center gap-2">
                                                    <div class="w-12 bg-slate-200 rounded-full h-1.5">
                                                        <div class="bg-emerald-500 h-1.5 rounded-full" style="width: 98%"></div>
                                                    </div>
                                                    <span class="text-emerald-600 font-bold">98%</span>
                                                </div>
                                            </td>
                                            <td class="px-5 py-4">
                                                <span class="bg-emerald-100 text-emerald-800 px-2 py-0.5 rounded-full font-medium text-[10px]">Synced to Sheets</span>
                                            </td>
                                            <td class="px-5 py-4 text-right">
                                                <button class="text-slate-400 hover:text-[#5E35B1]"><span class="material-symbols-rounded text-base">visibility</span></button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- Side Metric Box (AI Insights) -->
                        <div class="bg-white rounded-[14px] border border-slate-200 p-5 shadow-sm space-y-4">
                            <h3 class="font-bold text-slate-800 text-sm">System Insights</h3>
                            <div class="bg-indigo-50 p-4 rounded-[14px] border border-indigo-100 space-y-2">
                                <div class="flex items-center gap-2 text-[#5E35B1] font-semibold text-xs">
                                    <span class="material-symbols-rounded text-base">auto_awesome</span>
                                    <span>AI Assistant Recommendation</span>
                                </div>
                                <p class="text-xs text-indigo-950 leading-relaxed">
                                    Data entry speed improved by <strong>62%</strong> after configuring pre-filled mapping rules for "Global Logistics Inc.".
                                </p>
                            </div>

                            <div class="space-y-3">
                                <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Storage & Database Links</h4>
                                <div class="flex items-center justify-between p-3 border border-slate-100 rounded-lg text-xs">
                                    <div class="flex items-center gap-2 text-slate-600">
                                        <span class="material-symbols-rounded text-green-600">table_rows</span>
                                        <span>Primary Datasheet</span>
                                    </div>
                                    <span class="text-[11px] text-[#5E35B1] font-semibold hover:underline cursor-pointer">Open Sheet</span>
                                </div>
                                <div class="flex items-center justify-between p-3 border border-slate-100 rounded-lg text-xs">
                                    <div class="flex items-center gap-2 text-slate-600">
                                        <span class="material-symbols-rounded text-amber-500">folder</span>
                                        <span>Drive PDF Backup</span>
                                    </div>
                                    <span class="text-[11px] text-[#5E35B1] font-semibold hover:underline cursor-pointer">Open Drive</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


                <!-- PAGE 2: SALES INVOICE (AI-Assisted Entry Interface) -->
                <div id="tab-sales" class="tab-content hidden space-y-6">
                    <!-- Workflow Top Actions -->
                    <div class="flex items-center justify-between flex-wrap gap-4 bg-white p-4 rounded-[14px] border border-slate-200">
                        <div class="flex items-center gap-3">
                            <button class="bg-indigo-50 text-[#5E35B1] font-semibold text-xs px-3 py-2 rounded-lg hover:bg-indigo-100 flex items-center gap-2">
                                <span class="material-symbols-rounded text-sm">upload_file</span>
                                <span>Upload PDF</span>
                            </button>
                            <div class="text-xs text-slate-400">or drop single invoice here</div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button class="bg-[#5E35B1] text-white text-xs px-4 py-2 rounded-lg hover:bg-[#673AB7] flex items-center gap-2 font-medium">
                                <span class="material-symbols-rounded text-sm">auto_awesome</span>
                                <span>Run AI Extraction</span>
                            </button>
                            <span class="h-6 w-px bg-slate-200"></span>
                            <button class="bg-emerald-600 text-white text-xs px-4 py-2 rounded-lg hover:bg-emerald-700 flex items-center gap-2 font-medium">
                                <span class="material-symbols-rounded text-sm">done_all</span>
                                <span>Approve & Sync to Sheet</span>
                            </button>
                        </div>
                    </div>

                    <!-- Split Screen UI -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        
                        <!-- Left Screen Mock: Document Preview with AI Annotation overlays -->
                        <div class="bg-slate-200 rounded-[14px] border border-slate-300 min-h-[500px] flex flex-col relative overflow-hidden bg-cover bg-center shadow-inner" style="background-image: linear-gradient(rgba(255,255,255,0.9), rgba(255,255,255,0.95)), url('https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?auto=format&fit=crop&q=80&w=1000');">
                            <div class="p-4 bg-slate-100 border-b border-slate-200 flex items-center justify-between z-10">
                                <span class="text-xs font-semibold text-slate-700">Source: inv_0041_acmetech.pdf</span>
                                <div class="flex items-center gap-1">
                                    <button class="p-1 text-slate-500 hover:bg-slate-200 rounded"><span class="material-symbols-rounded text-sm">zoom_in</span></button>
                                    <button class="p-1 text-slate-500 hover:bg-slate-200 rounded"><span class="material-symbols-rounded text-sm">zoom_out</span></button>
                                </div>
                            </div>
                            <!-- Mock Document Visual overlays (mimicking Gemini extraction visual bounds) -->
                            <div class="flex-1 p-8 relative flex flex-col justify-between">
                                <!-- Top Area: Vendor Info & Inv Details Overlay -->
                                <div class="flex justify-between items-start">
                                    <div class="border-2 border-dashed border-[#5E35B1] bg-[#5E35B1]/10 p-2 rounded text-xs select-none relative">
                                        <span class="absolute -top-4 left-0 bg-[#5E35B1] text-white text-[8px] px-1 rounded">Vendor Info</span>
                                        <strong>ACME TECH SOLUTIONS</strong><br>
                                        102 Enterprise Way, Suite 4
                                    </div>
                                    <div class="border-2 border-dashed border-[#5E35B1] bg-[#5E35B1]/10 p-2 rounded text-xs select-none relative text-right">
                                        <span class="absolute -top-4 right-0 bg-[#5E35B1] text-white text-[8px] px-1 rounded">Invoice Details</span>
                                        Invoice #: <strong class="text-[#5E35B1]">INV-2025-0041</strong><br>
                                        Date: <strong>24-Jan-2025</strong>
                                    </div>
                                </div>

                                <!-- Center Area: Items list visual simulation -->
                                <div class="border-2 border-dashed border-[#5E35B1] bg-[#5E35B1]/10 p-4 rounded text-xs my-auto relative">
                                    <span class="absolute -top-4 left-0 bg-[#5E35B1] text-white text-[8px] px-1 rounded">Line Items (Gemini Parsed)</span>
                                    <table class="w-full text-left text-[11px]">
                                        <thead>
                                            <tr class="border-b border-dashed border-[#5E35B1]/30">
                                                <th>Item</th>
                                                <th>Qty</th>
                                                <th>Price</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>Cloud Compute Subscription (Tier 3)</td>
                                                <td>1</td>
                                                <td>$1,200.00</td>
                                            </tr>
                                            <tr>
                                                <td>API Gateway Setup Fees</td>
                                                <td>1</td>
                                                <td>$450.00</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Bottom Area: Totals Annotation -->
                                <div class="flex justify-end">
                                    <div class="border-2 border-dashed border-emerald-600 bg-emerald-500/10 p-2 rounded text-xs select-none relative text-right w-40">
                                        <span class="absolute -top-4 right-0 bg-emerald-600 text-white text-[8px] px-1 rounded">Total Amount</span>
                                        Subtotal: $1,650.00<br>
                                        Tax (18%): $297.00<br>
                                        <strong>Total: $1,947.00</strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Right Screen: Editable AI Extractions fields -->
                        <div class="bg-white rounded-[14px] border border-slate-200 p-5 shadow-sm space-y-4">
                            <div class="flex items-center justify-between border-b border-slate-100 pb-3">
                                <h3 class="font-bold text-slate-800 text-sm">AI-Assisted Field Map</h3>
                                <div class="flex items-center gap-1 bg-emerald-50 text-emerald-700 text-xs px-2 py-0.5 rounded-full font-semibold">
                                    <span class="material-symbols-rounded text-sm">insights</span>
                                    <span>High Confidence</span>
                                </div>
                            </div>

                            <!-- Document Fields Forms -->
                            <form class="space-y-4">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-500 mb-1">Customer / Vendor Account</label>
                                        <select class="w-full border border-slate-200 rounded-lg p-2.5 text-xs focus:ring-1 focus:ring-[#5E35B1] focus:outline-none">
                                            <option>Acme Tech Solutions (C-00341)</option>
                                            <option>Global Logistics Inc. (V-00892)</option>
                                            <option>Nvidia Corp India (C-00109)</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-500 mb-1">Tax Code Alignment</label>
                                        <select class="w-full border border-slate-200 rounded-lg p-2.5 text-xs focus:ring-1 focus:ring-[#5E35B1] focus:outline-none">
                                            <option>GST 18% (Standard Services)</option>
                                            <option>GST 5% (Logistics)</option>
                                            <option>Exempt / Zero Rated</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                    <div>
